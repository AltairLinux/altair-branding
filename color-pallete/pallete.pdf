from reportlab.lib.pagesizes import A4
from reportlab.pdfgen import canvas
from reportlab.lib import colors

# Define Altair Linux colors
palette = [
    {"name": "Primary: Deep Space Navy", "hex": "#0B1D3A"},
    {"name": "Accent: Stellar Cyan", "hex": "#3FD0FF"},
    {"name": "Secondary: Solar Gold", "hex": "#FFC857"},
    {"name": "Neutral: Soft White", "hex": "#F5F7FA"},
    {"name": "Secondary Neutral: Light Gray", "hex": "#B0B8C2"},
]

# Create PDF
c = canvas.Canvas("color_palette.pdf", pagesize=A4)
width, height = A4

# Layout variables
block_width = 400
block_height = 100
margin_top = 700
margin_left = 50
spacing = 20

# Draw title
c.setFont("Helvetica-Bold", 24)
c.drawString(margin_left, margin_top + 50, "Altair Linux Color Palette")

for i, color in enumerate(palette):
    y = margin_top - i * (block_height + spacing)
    
    # Draw color rectangle
    c.setFillColor(colors.HexColor(color["hex"]))
    c.rect(margin_left, y, block_width, block_height, fill=1, stroke=0)
    
    # Draw color name & hex
    c.setFillColor(colors.black if color["name"] != "Neutral: Soft White" else colors.HexColor("#0B1D3A"))
    c.setFont("Helvetica-Bold", 14)
    c.drawString(margin_left + 10, y + block_height / 2 + 5, color["name"])
    c.setFont("Helvetica", 12)
    c.drawString(margin_left + 10, y + block_height / 2 - 15, color["hex"])

# Save PDF
c.save()
print("Altair Linux color palette PDF generated as color_palette.pdf")
